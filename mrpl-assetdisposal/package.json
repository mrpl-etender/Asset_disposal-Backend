{
  "name": "mrpl-assetdisposal",
  "version": "1.0.0",
  "description": "Asset Disposal",
  "repository": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.13.1",
    "@cap-js/hana": "^1",
    "@sap/cds": "^8",
    "@sap/cds-odata-v2-adapter-proxy": "^1.9.21",
    "@sap/xssec": "^4",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.6",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "rimraf resources mta_archives && mbt build --mtar mrpl-assetdisposal_1.0.0.mtar",
    "deploy": "cf deploy mta_archives/mrpl-assetdisposal_1.0.0.mtar --retries 1",
    "kill": "kill -9 $(lsof -PiTCP -sTCP:LISTEN | grep 4004 | awk '{print $2}')"
  },
  "cds": {
    "requires": {
      "auth": "mocked",
      "connectivity": true,
      "destinations": true,
      "html5-repo": true,
      "application-logging": true,
      "ZMM_DAN_TO_SALES_SRV1_ZMM_DAN_TO_SALES_SRVxml": {
        "kind": "odata-v2",
        "model": "srv/external/ZMM_DAN_TO_SALES_SRV1.ZMM_DAN_TO_SALES_SRVxml"
      },
      "ZMM_DAN_TO_SALES_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/ZMM_DAN_TO_SALES_SRV"
      }
    },
    "auth": {
      "strategy": "jwt"
    },
    "destinations": true,
    "connectivity": true,
    "db": {
      "kind": "sqlite"
    },
    "html5-repo": true,
    "workzone": true,
    "[production]": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "xsuaa"
      }
    },
    "[development]": {
      "auth": {
        "kind": "mocked",
        "users": {
          "mrpl": {
            "roles": [
              "admin"
            ]
          },
          "alice": {
            "roles": [
              "support"
            ]
          }
        }
      }
    }
  }
}